{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*":        ["../../packages/shared/src/*"],
      "@features/*":      ["./src/features/*"],
      "@navigation/*":    ["./src/navigation/*"],
      "@mobile/shared/*": ["./src/shared/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "../../packages/shared/src/**/*.ts",
    "../../packages/shared/src/**/*.tsx"
  ]
}
