# ============================================================
# Runivo — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored — never commit real keys.
# ============================================================

# Supabase project URL (Settings > API > Project URL)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (Settings > API > Project API keys > anon public)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Stripe (optional — leave blank to show placeholder alert) ──────────────────
VITE_STRIPE_LINK_RUNNER_PLUS=
VITE_STRIPE_LINK_TERRITORY_LORD=
VITE_STRIPE_LINK_EMPIRE_BUILDER=

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Generate a VAPID key pair once: npx web-push generate-vapid-keys
# VITE_VAPID_PUBLIC_KEY is safe to expose to the client (it's a public key).
# Add VAPID_PRIVATE_KEY + VAPID_SUBJECT to Supabase Edge Function secrets.
VITE_VAPID_PUBLIC_KEY=

# ── Runivo Intelligence (AI Coach) ────────────────────────────────────────────
# The Anthropic API key is used SERVER-SIDE ONLY in the ai-coach Supabase edge
# function. It is NEVER exposed to the client.
# Add this key in Supabase Dashboard > Edge Functions > Secrets:
#   Key: ANTHROPIC_API_KEY
#   Value: sk-ant-api03-...
#
# For local edge function development (supabase functions serve):
# Add to supabase/functions/.env (git-ignored):
#   ANTHROPIC_API_KEY=sk-ant-api03-...
